{
  "name": "goodrequest-frontend-assignment",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 4173",
    "build": "next build && node scripts/finalize-static-export.mjs",
    "typecheck": "next typegen && tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:styles": "stylelint 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "performance": "node scripts/check-performance.mjs",
    "bundle:check": "node scripts/check-bundle-budget.mjs",
    "check": "pnpm format:check && pnpm lint && pnpm lint:styles && pnpm typecheck && pnpm test && pnpm build && pnpm bundle:check",
    "api:types": "openapi-typescript docs/openapi.json -o src/lib/api/generated.ts",
    "deadcode": "knip"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.4",
    "i18next": "26.3.6",
    "libphonenumber-js": "1.13.9",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-hook-form": "7.82.0",
    "react-i18next": "17.0.10",
    "styled-components": "6.4.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "chrome-launcher": "1.2.1",
    "eslint": "10.7.0",
    "eslint-config-next": "16.2.11",
    "jest-styled-components": "7.4.0",
    "jsdom": "29.1.1",
    "knip": "6.29.0",
    "lighthouse": "13.4.1",
    "msw": "2.15.0",
    "openapi-typescript": "7.13.0",
    "postcss-styled-syntax": "0.7.2",
    "prettier": "3.9.6",
    "stylelint": "17.14.1",
    "stylelint-config-standard": "40.0.0",
    "typescript": "7.0.2",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10"
  }
}
